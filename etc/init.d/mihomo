#!/bin/sh
#
# /etc/init.d/mihomo
#

### BEGIN INIT INFO
# Provides:          mihomo
# Required-Start:    $network $remote_fs
# Required-Stop:     $network $remote_fs
# Default-Start:     3 5
# Default-Stop:      0 1 6
# Short-Description: Mihomo Service
# Description:       Start/Stop Mihomo Proxy Service
### END INIT INFO

NAME="mihomo"
BIN="/usr/local/bin/mihomo"
CONF_DIR="/etc/mihomo"
PIDDIR="/var/run/mihomo"
PIDFILE="${PIDDIR}/mihomo.pid"
LOGFILE="/var/log/mihomo.log"

ensure_dirs() {
    install -d -m 755 "$PIDDIR"
    install -d -m 755 /var/log

    touch "$LOGFILE"
    chmod 755 "$PIDDIR"
    chmod 644 "$LOGFILE"
}

is_running() {
    if [ -f "$PIDFILE" ]; then
        PID="$(cat "$PIDFILE" 2>/dev/null)"
        if [ -n "$PID" ] && kill -0 "$PID" 2>/dev/null; then
            return 0
        fi
    fi
    return 1
}

check_config() {
    "$BIN" -t -d "$CONF_DIR" >/dev/null 2>&1
    return $?
}

start() {
    echo "Starting $NAME..."

    ensure_dirs

    if is_running; then
        echo "$NAME already running."
        return 0
    fi

    if ! check_config; then
        echo "Configuration test failed."
        return 1
    fi

    "$BIN" -d "$CONF_DIR" >> "$LOGFILE" 2>&1 &
    PID=$!
    echo "$PID" > "$PIDFILE"

    sleep 1

    if kill -0 "$PID" 2>/dev/null; then
        echo "$NAME started."
        return 0
    else
        echo "Failed to start $NAME!"
        rm -f "$PIDFILE"
        return 1
    fi
}

stop() {
    echo "Stopping $NAME..."

    if is_running; then
        PID="$(cat "$PIDFILE" 2>/dev/null)"
        kill "$PID" 2>/dev/null
        sleep 1

        if kill -0 "$PID" 2>/dev/null; then
            kill -9 "$PID" 2>/dev/null
        fi

        rm -f "$PIDFILE"
        echo "$NAME stopped."
        return 0
    else
        rm -f "$PIDFILE"
        echo "$NAME is not running."
        return 0
    fi
}

restart() {
    stop
    sleep 1
    start
}

status() {
    if is_running; then
        echo "running"
        return 0
    else
        echo "stopped"
        return 1
    fi
}

case "$1" in
    start)
        start
        ;;
    stop)
        stop
        ;;
    restart)
        restart
        ;;
    status)
        status
        ;;
    *)
        echo "Usage: $0 {start|stop|restart|status}"
        exit 1
        ;;
esac

exit $?